{
  "/search": {
    "url": "https://html.duckduckgo.com/html/?q={{query}}",
    "list": ".result",
    "result": {
      "title": ".result__title a",
      "url": [".result__url", "@href"],
      "snippet": ".result__snippet"
    }
  },
  "/api": {
    "mode": "json",
    "url": "https://api.duckduckgo.com/?q={{query}}&format=json",
    "list": ".",
    "result": {
      "heading": ".Heading",
      "abstract": ".AbstractText",
      "source": ".AbstractSource",
      "url": ".AbstractURL",
      "image": ".Image"
    }
  }
}
